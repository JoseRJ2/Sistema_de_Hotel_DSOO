# Normalizar finales de línea automáticamente
* text=auto

# Archivos de código: siempre LF en el repositorio
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.env*  text eol=lf

# Archivos binarios: sin conversión
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.woff  binary
*.woff2 binary
